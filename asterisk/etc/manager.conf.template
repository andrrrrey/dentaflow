; AMI для оркестратора ИИ-обзвона (Originate). Рендерится entrypoint.sh из env.
; Доступ только из docker-сети (backend/celery), наружу порт не публикуем.
[general]
enabled = yes
port = 5038
bindaddr = 0.0.0.0

[dentaflow]
secret = ${AMI_PASSWORD}
deny = 0.0.0.0/0.0.0.0
permit = 127.0.0.1/255.255.255.255
permit = 10.0.0.0/255.0.0.0
permit = 172.16.0.0/255.240.0.0
permit = 192.168.0.0/255.255.0.0
read = system,call,verbose,command,originate
write = system,call,verbose,command,originate
