# Окружение приложения (development / staging / production)
APP_ENV=development

# Секретный ключ для подписи JWT-токенов и сессий (минимум 32 символа, обязательно сменить в продакшене)
SECRET_KEY=change-me-to-a-random-secret-key-32ch

# Разрешённые источники для CORS (через запятую, если несколько)
ALLOWED_ORIGINS=http://localhost:5173

# URL подключения к PostgreSQL (asyncpg-драйвер)
DATABASE_URL=postgresql+asyncpg://dentaflow:dentaflow@postgres:5432/dentaflow

# URL подключения к Redis
REDIS_URL=redis://redis:6379/0

# Пароль PostgreSQL (должен совпадать с POSTGRES_PASSWORD в docker-compose)
POSTGRES_PASSWORD=dentaflow

# URL API 1Denta (базовый адрес)
ONE_DENTA_API_URL=https://api.1denta.com

# Ключ доступа к API 1Denta
ONE_DENTA_API_KEY=your-one-denta-api-key

# Ключ доступа к API Novofon (телефония)
NOVOFON_API_KEY=your-novofon-api-key

# Секрет для проверки вебхуков Novofon
NOVOFON_WEBHOOK_SECRET=your-novofon-webhook-secret

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ

# Секрет для проверки вебхуков Telegram
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# Chat ID владельца для системных уведомлений в Telegram
OWNER_TELEGRAM_CHAT_ID=123456789

# Ключ API OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Модель OpenAI для генерации текста
OPENAI_MODEL=gpt-4o

# Ключ API MAX (рассылки / маркетинг)
MAX_API_KEY=your-max-api-key

# Токен подтверждения MAX
MAX_CONFIRMATION_TOKEN=your-max-confirmation-token
