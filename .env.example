# ============================================================
# DentaFlow — переменные окружения
# Скопируйте в .env и заполните реальными значениями
# ============================================================

# ── Общие настройки приложения ────────────────────────────────

# Окружение приложения (development / staging / production)
APP_ENV=development

# Секретный ключ для подписи JWT-токенов и сессий
# Минимум 32 символа, обязательно сменить в продакшене!
SECRET_KEY=change-me-to-a-random-secret-key-32ch

# Разрешённые источники для CORS (через запятую, если несколько)
# В продакшене указать реальный домен: https://dentaflow.ru
ALLOWED_ORIGINS=http://localhost:5173

# Домен приложения (используется для формирования ссылок)
APP_DOMAIN=localhost

# ── JWT-токены ────────────────────────────────────────────────

# Время жизни access-токена (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Время жизни refresh-токена (в днях)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── База данных PostgreSQL ────────────────────────────────────

# URL подключения к PostgreSQL (asyncpg-драйвер)
DATABASE_URL=postgresql+asyncpg://dentaflow:dentaflow@postgres:5432/dentaflow

# Пароль PostgreSQL (должен совпадать с POSTGRES_PASSWORD в docker-compose)
# В продакшене задать надёжный пароль!
POSTGRES_PASSWORD=dentaflow

# ── Redis ─────────────────────────────────────────────────────

# URL подключения к Redis (брокер задач Celery + кеш)
REDIS_URL=redis://redis:6379/0

# ── Интеграция 1Denta ─────────────────────────────────────────

# URL API 1Denta (базовый адрес)
ONE_DENTA_API_URL=https://api.1denta.com

# Ключ доступа к API 1Denta
ONE_DENTA_API_KEY=your-one-denta-api-key

# ── Телефония Novofon ─────────────────────────────────────────

# Ключ доступа к API Novofon
NOVOFON_API_KEY=your-novofon-api-key

# Секрет для проверки вебхуков Novofon
NOVOFON_WEBHOOK_SECRET=your-novofon-webhook-secret

# ── Telegram-бот ──────────────────────────────────────────────

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ

# Секрет для проверки вебхуков Telegram
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# Chat ID владельца для системных уведомлений в Telegram
OWNER_TELEGRAM_CHAT_ID=123456789

# ── OpenAI (AI-аналитика) ────────────────────────────────────

# Ключ API OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Модель OpenAI для генерации текста
OPENAI_MODEL=gpt-4o

# ── MAX (рассылки / маркетинг) ────────────────────────────────

# Ключ API MAX
MAX_API_KEY=your-max-api-key

# Токен подтверждения MAX
MAX_CONFIRMATION_TOKEN=your-max-confirmation-token

# ── SSL / Let's Encrypt (только продакшен) ────────────────────

# Email для уведомлений о сертификатах Let's Encrypt
# CERTBOT_EMAIL=admin@dentaflow.ru
